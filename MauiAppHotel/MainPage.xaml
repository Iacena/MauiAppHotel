<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.MainPage"
             Title="Reserva de Hospedagem"
             BackgroundColor="#F4F6F9">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Button Text="Sobre o Desenvolvedor" 
                    BackgroundColor="#34495E" 
                    TextColor="White" 
                    FontAttributes="Italic"
                    FontSize="12"
                    HorizontalOptions="End"
                    HeightRequest="35"
                    Clicked="OnSobreClicked" />

            <Label Text="App Hotel" 
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2C3E50" 
                   HorizontalOptions="Center" />

            <Border Stroke="#BDC3C7" StrokeThickness="1" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Período da Estadia" FontAttributes="Bold" TextColor="#34495E" />

                    <Label Text="Data de Check-In:" TextColor="#34495E" />
                    <DatePicker x:Name="dtpCheckIn" Format="dd/MM/yyyy" DateSelected="OnDataSelecionada" TextColor="Black" />

                    <Label Text="Data de Check-Out:" TextColor="#34495E" />
                    <DatePicker x:Name="dtpCheckOut" Format="dd/MM/yyyy" TextColor="Black" />
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#BDC3C7" StrokeThickness="1" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Quantidade de Hóspedes" FontAttributes="Bold" TextColor="#34495E" />

                    <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                        <Label Text="Adultos:" VerticalOptions="Center" WidthRequest="80" TextColor="#34495E" />
                        <Stepper x:Name="stpAdultos" Minimum="1" Maximum="10" Increment="1" Value="1" BackgroundColor="#BDC3C7" />
                        <Label Text="{Binding Source={x:Reference stpAdultos}, Path=Value, StringFormat='{0:F0}'}" VerticalOptions="Center" TextColor="Black" />
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="20" VerticalOptions="Center">
                        <Label Text="Crianças:" VerticalOptions="Center" WidthRequest="80" TextColor="#34495E" />
                        <Stepper x:Name="stpCriancas" Minimum="0" Maximum="10" Increment="1" Value="0" BackgroundColor="#BDC3C7" />
                        <Label Text="{Binding Source={x:Reference stpCriancas}, Path=Value, StringFormat='{0:F0}'}" VerticalOptions="Center" TextColor="Black" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Stroke="#BDC3C7" StrokeThickness="1" Padding="15">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="Escolha o Quarto" FontAttributes="Bold" TextColor="#34495E" />

                    <Picker x:Name="pckQuartos" 
                        Title="Selecione uma opção..." 
                        ItemDisplayBinding="{Binding Descricao}" 
                        TextColor="Black" 
                        TitleColor="#34495E" 
                        BackgroundColor="#EAECEE" />    
                </VerticalStackLayout>
            </Border>

            <Button Text="Avançar" 
                    BackgroundColor="#2ECC71" 
                    TextColor="White" 
                    FontAttributes="Bold" 
                    FontSize="18"
                    CornerRadius="8" 
                    HeightRequest="50" 
                    Clicked="OnAvancarClicked" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>